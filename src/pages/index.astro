---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import StarField from '../components/StarField';
import SpaceParticles from '../components/SpaceParticles';
import ScrollRocket from '../components/ScrollRocket';
import PageLoader from '../components/PageLoader';
import GlobalLiquidEther from '../components/GlobalLiquidEther';
import Hero from '../components/Hero';
import About from '../components/About';
import Skills from '../components/Skills';
import Projects from '../components/Projects';
import Contact from '../components/Contact';
---

<Layout>
	<PageLoader client:only="react" />
	<GlobalLiquidEther client:load />
	<StarField client:load />
	<SpaceParticles client:load />
	<ScrollRocket client:load />
	<Navbar client:load />
	<Hero client:load />
	<About client:visible />
	<Projects client:visible />
	<Contact client:visible />
</Layout>
